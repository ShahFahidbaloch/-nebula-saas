# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # never expose to client!

# ─── Resend (email) ────────────────────────────────────────────────────────────
# Get from: https://resend.com → API Keys
RESEND_API_KEY=re_your_key_here
# Domain you've verified in Resend (or use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=hello@yourdomain.com
RESEND_FROM_NAME=Nebula
# Where admin notifications go
ADMIN_NOTIFY_EMAIL=you@yourdomain.com

# ─── hCaptcha ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.hcaptcha.com
# Dev test keys (always pass, no real challenge):
#   site key:   10000000-ffff-ffff-ffff-000000000001
#   secret key: 0x0000000000000000000000000000000000000000
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# ─── App ───────────────────────────────────────────────────────────────────────
# Full base URL (no trailing slash) — used in confirmation emails
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Admin ─────────────────────────────────────────────────────────────────────
# HTTP Basic Auth for /admin — browser shows native login dialog
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
